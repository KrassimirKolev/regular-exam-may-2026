#!/bin/sh

# Read the last commit message (works on Windows)
commit_msg="$(git log -1 --pretty=%B)"

# Validate commit message format
echo "$commit_msg" | grep -Eq "^TASK-[0-9]+: .+"
if [ $? -ne 0 ]; then
  echo "❌ Invalid commit message format!"
  echo "Expected: TASK-123: Description"
  exit 1
fi

exit 0
