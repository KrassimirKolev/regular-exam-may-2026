#!/bin/bash

echo "Running tests before push..."

if command -v npm >/dev/null 2>&1; then
  npm test
  if [ $? -ne 0 ]; then
    echo "❌ Tests failed! Push blocked."
    exit 1
  fi
fi

if command -v dotnet >/dev/null 2>&1; then
  dotnet test
  if [ $? -ne 0 ]; then
    echo "❌ Tests failed! Push blocked."
    exit 1
  fi
fi

echo "✔ Tests passed. Push allowed."
exit 0
